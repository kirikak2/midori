menu "USB MIDI Host Configuration"

    choice USB_MIDI_BOARD_TYPE
        prompt "Target Board"
        default USB_MIDI_BOARD_FREENOVE
        help
            Select the target hardware board.

        config USB_MIDI_BOARD_FREENOVE
            bool "Freenove ESP32-S3"
            help
                Freenove ESP32-S3 board with separate USB-C for host and serial.
                Logs output to serial console.

        config USB_MIDI_BOARD_M5STACK_CORES3
            bool "M5Stack CoreS3 SE"
            help
                M5Stack CoreS3 SE board with shared USB-C.
                Logs output to LCD display.
    endchoice

    menu "M5Stack Display Settings"
        depends on USB_MIDI_BOARD_M5STACK_CORES3

        config USB_MIDI_LCD_FONT_SIZE
            int "LCD Font Size (pixels)"
            default 1
            range 1 3
            help
                Font size multiplier for LCD console text.
                1 = small (6x8), 2 = medium (12x16), 3 = large (18x24)

        config USB_MIDI_LCD_BACKLIGHT_LEVEL
            int "LCD Backlight Level (0-255)"
            default 200
            range 0 255
            help
                Backlight brightness level.

    endmenu

    menu "SD Card Settings"
        config USB_MIDI_SDCARD_ENABLED
            bool "Enable SD Card"
            default y
            help
                Enable SD card support for loading app.rb script.

        menu "M5Stack CoreS3 SD Card Pins"
            depends on USB_MIDI_BOARD_M5STACK_CORES3 && USB_MIDI_SDCARD_ENABLED

            config USB_MIDI_SDCARD_M5_CLK
                int "SD CLK GPIO"
                default 36
            config USB_MIDI_SDCARD_M5_MOSI
                int "SD MOSI GPIO"
                default 37
            config USB_MIDI_SDCARD_M5_MISO
                int "SD MISO GPIO"
                default 35
            config USB_MIDI_SDCARD_M5_CS
                int "SD CS GPIO"
                default 4
        endmenu

        menu "Freenove SD Card Pins"
            depends on USB_MIDI_BOARD_FREENOVE && USB_MIDI_SDCARD_ENABLED

            config USB_MIDI_SDCARD_FREENOVE_CLK
                int "SD CLK GPIO"
                default 12
            config USB_MIDI_SDCARD_FREENOVE_MOSI
                int "SD MOSI GPIO"
                default 11
            config USB_MIDI_SDCARD_FREENOVE_MISO
                int "SD MISO GPIO"
                default 13
            config USB_MIDI_SDCARD_FREENOVE_CS
                int "SD CS GPIO"
                default 10
        endmenu

        config USB_MIDI_SDCARD_MOUNT_POINT
            string "SD Card Mount Point"
            default "/sdcard"
            depends on USB_MIDI_SDCARD_ENABLED
            help
                Mount point for the SD card filesystem.

        config USB_MIDI_APP_SCRIPT_PATH
            string "Ruby Script Path"
            default "/sdcard/app.rb"
            depends on USB_MIDI_SDCARD_ENABLED
            help
                Path to the Ruby script to execute on startup.
    endmenu

endmenu
